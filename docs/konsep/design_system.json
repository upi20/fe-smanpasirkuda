{
  "meta": {
    "name": "SMAN 1 Pasir Kuda - Design System (Konsep)",
    "version": "0.1.0",
    "status": "concept",
    "source": {
      "referenceSite": "sman1bdg.sch.id",
      "referenceSnapshot": "referensi/sman1bdg.sch.id/index.html",
      "notes": [
        "Token warna & beberapa ukuran diambil dari CSS inline <style id=custom-css> pada snapshot referensi.",
        "Snapshot referensi mengandung link tersembunyi/spam di footer; itu bukan bagian dari desain dan harus diabaikan saat implementasi."
      ]
    }
  },
  "tokens": {
